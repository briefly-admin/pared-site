# ============================================================
# PARED — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Email provider (uncomment the one you choose in app/api/subscribe/route.js)

# Buttondown
BUTTONDOWN_API_KEY=

# ConvertKit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
